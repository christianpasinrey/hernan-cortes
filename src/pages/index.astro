---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import ChapterNav from '../components/ChapterNav.astro';
import Chapter from '../components/Chapter.astro';
import Quote from '../components/Quote.astro';
import ParallaxImage from '../components/ParallaxImage.astro';
import Gallery from '../components/Gallery.astro';
import Timeline from '../components/Timeline.astro';
import chaptersData from '../data/chapters.json';

// Chapters that get a timeline (2: Cuba events, 7: last years)
const timelineChapters = [2, 7];
---

<Base>
  <main>
    <Hero />
    <ChapterNav />

    {chaptersData.chapters.map((ch) => (
      <Chapter
        id={ch.id}
        number={ch.number}
        title={ch.title}
        subtitle={ch.subtitle}
        accentColor={ch.accentColor}
        bgColor={ch.bgColor}
      >
        {ch.images?.filter(img => img.usage === 'hero' || img.usage === 'parallax').slice(0, 1).map(img => (
          <ParallaxImage
            src={img.url}
            alt={img.alt}
            width={img.width}
            height={img.height}
          />
        ))}

        {ch.narrative.map((para) => (
          <p data-animate="fade-up">{para}</p>
        ))}

        {ch.quotes?.map(q => (
          <Quote text={q.text} author={q.author} source={q.source} />
        ))}

        {ch.number === 5 && (
          <div class="city-comparison" data-animate="fade-up">
            <h3 style="color: var(--accent-gold); margin-bottom: 2rem; text-align: center;">Población circa 1519</h3>
            <div class="city-comparison__grid">
              <div class="city-comparison__item">
                <div class="city-comparison__bar" style="height: 200px; background: var(--accent-gold);"></div>
                <span class="city-comparison__name">Tenochtitlán</span>
                <span class="city-comparison__pop">~200,000</span>
              </div>
              <div class="city-comparison__item">
                <div class="city-comparison__bar" style="height: 100px; background: var(--accent-stone);"></div>
                <span class="city-comparison__name">París</span>
                <span class="city-comparison__pop">~100,000</span>
              </div>
              <div class="city-comparison__item">
                <div class="city-comparison__bar" style="height: 50px; background: var(--accent-stone);"></div>
                <span class="city-comparison__name">Londres</span>
                <span class="city-comparison__pop">~50,000</span>
              </div>
            </div>
          </div>
        )}

        {timelineChapters.includes(ch.number) && ch.keyDates?.length > 0 && (
          <Timeline dates={ch.keyDates} />
        )}

        {(() => {
          const galleryImages = ch.images?.filter(img => img.usage === 'gallery');
          return galleryImages?.length > 0 ? <Gallery images={galleryImages} /> : null;
        })()}
      </Chapter>
    ))}
  </main>

  <script>
    import { initAnimations } from '../scripts/animations.js';
    import { initGalleries } from '../scripts/gallery.js';
    import { initTimelines } from '../scripts/timeline.js';
    initAnimations();
    initGalleries();
    initTimelines();
  </script>
</Base>
