---
interface Props {
  src: string;
  alt: string;
  number: number;
  title: string;
  subtitle: string;
  accentColor?: string;
}
const { src, alt, number, title, subtitle, accentColor = '--accent-gold' } = Astro.props;
---

<div class="fs-hero" data-fs-hero style={`--chapter-accent: var(${accentColor});`}>
  <div class="fs-hero__image-wrap">
    <img src={src} alt={alt} class="fs-hero__image" loading="lazy" decoding="async" onerror="this.style.display='none'" />
    <div class="fs-hero__overlay"></div>
  </div>
  <div class="fs-hero__content">
    <span class="fs-hero__number">{String(number).padStart(2, '0')}</span>
    <h2 class="fs-hero__title">{title}</h2>
    <p class="fs-hero__subtitle">{subtitle}</p>
  </div>
</div>

<style>
  .fs-hero {
    position: relative;
    height: 100vh;
    overflow: hidden;
  }

  .fs-hero__image-wrap {
    position: absolute;
    inset: 0;
  }

  .fs-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .fs-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(10, 10, 10, 0.3) 0%,
      rgba(10, 10, 10, 0.6) 50%,
      rgba(10, 10, 10, 0.95) 100%
    );
  }

  .fs-hero__content {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    z-index: 2;
    padding: 2rem;
  }

  .fs-hero__number {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2vw, 1.4rem);
    color: var(--chapter-accent);
    letter-spacing: 0.3em;
    opacity: 0;
  }

  .fs-hero__title {
    color: var(--text-primary);
    margin-top: 0.5rem;
    opacity: 0;
    transform: translateY(20px);
  }

  .fs-hero__subtitle {
    font-family: var(--font-quote);
    font-style: italic;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--text-secondary);
    margin-top: 0.5rem;
    letter-spacing: 0.15em;
    opacity: 0;
  }

  @media (prefers-reduced-motion: reduce) {
    .fs-hero__number,
    .fs-hero__title,
    .fs-hero__subtitle {
      opacity: 1;
      transform: none;
    }
  }
</style>
