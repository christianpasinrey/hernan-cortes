---
import chaptersData from '../data/chapters.json';
---

<nav class="chapter-nav" id="chapter-nav" role="navigation" aria-label="Navegación por capítulos">
  <ul class="chapter-nav__list">
    {chaptersData.chapters.map((ch) => (
      <li class="chapter-nav__item">
        <a
          href={`#${ch.id}`}
          class="chapter-nav__dot"
          data-chapter-nav={ch.number}
          aria-label={`Capítulo ${ch.number}: ${ch.title}`}
          title={`${String(ch.number).padStart(2, '0')} — ${ch.title}`}
        >
          <span class="chapter-nav__label" aria-hidden="true">
            {String(ch.number).padStart(2, '0')}
          </span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<!-- Self-contained nav script — no dependency on GSAP or animations.js -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('chapter-nav');
    if (!nav) return;

    const dots = nav.querySelectorAll('.chapter-nav__dot');

    // Show nav after scrolling past the hero
    const hero = document.getElementById('hero');
    if (hero) {
      const observer = new IntersectionObserver(
        ([entry]) => {
          nav.classList.toggle('visible', !entry.isIntersecting);
        },
        { threshold: 0.1 }
      );
      observer.observe(hero);
    } else {
      // No hero? Show nav immediately
      nav.classList.add('visible');
    }

    // Click handler for each dot
    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const href = dot.getAttribute('href');
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });

    // Update active dot on scroll
    const chapters = document.querySelectorAll('[data-chapter]');
    const updateActiveDot = () => {
      const scrollY = window.scrollY + window.innerHeight / 2;
      let activeNum = null;

      chapters.forEach((ch) => {
        const top = ch.offsetTop;
        const bottom = top + ch.offsetHeight;
        if (scrollY >= top && scrollY < bottom) {
          activeNum = ch.dataset.chapter;
        }
      });

      dots.forEach((dot) => {
        const isActive = dot.dataset.chapterNav === activeNum;
        dot.classList.toggle('active', isActive);
      });
    };

    window.addEventListener('scroll', updateActiveDot, { passive: true });
    updateActiveDot();
  });
</script>

<style is:global>
  .chapter-nav {
    position: fixed;
    right: 1.5rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 1000;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .chapter-nav.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .chapter-nav__list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    margin: 0;
    padding: 0;
  }

  .chapter-nav__item {
    list-style: none;
  }

  .chapter-nav__dot {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1.5px solid rgba(139, 115, 85, 0.5);
    background: rgba(10, 10, 10, 0.7);
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    position: relative;
  }

  .chapter-nav__dot:hover {
    border-color: var(--accent-gold);
    background: rgba(201, 168, 76, 0.15);
    transform: scale(1.15);
  }

  .chapter-nav__dot.active {
    background: var(--accent-gold);
    border-color: var(--accent-gold);
    transform: scale(1.1);
  }

  .chapter-nav__label {
    font-family: var(--font-heading);
    font-size: 0.55rem;
    color: var(--text-secondary);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .chapter-nav__dot:hover .chapter-nav__label {
    color: var(--accent-gold);
  }

  .chapter-nav__dot.active .chapter-nav__label {
    color: var(--bg-primary);
    font-weight: 700;
  }

  /* Tablet */
  @media (max-width: 1024px) {
    .chapter-nav {
      right: 0.75rem;
    }
    .chapter-nav__dot {
      width: 24px;
      height: 24px;
    }
  }

  /* Mobile: hide sidebar, could add hamburger later */
  @media (max-width: 768px) {
    .chapter-nav {
      display: none;
    }
  }
</style>
