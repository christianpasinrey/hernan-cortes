---
import chaptersData from '../data/chapters.json';
---

<nav id="chapter-nav" role="navigation" aria-label="Navegación por capítulos" style="position:fixed;right:1.5rem;top:50%;transform:translateY(-50%);z-index:9999;opacity:0;pointer-events:none;transition:opacity 0.4s ease;">
  <ul style="list-style:none;display:flex;flex-direction:column;gap:0.6rem;margin:0;padding:0;">
    {chaptersData.chapters.map((ch) => (
      <li style="list-style:none;">
        <a
          href={`#${ch.id}`}
          class="cnav-dot"
          data-chapter-nav={String(ch.number)}
          aria-label={`Capítulo ${ch.number}: ${ch.title}`}
          title={`${String(ch.number).padStart(2, '0')} — ${ch.title}`}
          style="display:flex;align-items:center;justify-content:center;width:32px;height:32px;border-radius:50%;border:1.5px solid rgba(139,115,85,0.5);background:rgba(10,10,10,0.8);cursor:pointer;text-decoration:none;color:#b8b0a0;font-family:Georgia,serif;font-size:0.6rem;letter-spacing:0.05em;transition:all 0.3s ease;"
        >
          {String(ch.number).padStart(2, '0')}
        </a>
      </li>
    ))}
  </ul>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const nav = document.getElementById('chapter-nav');
    if (!nav) return;

    const dots = nav.querySelectorAll('.cnav-dot');

    // Show nav after scrolling past hero
    const hero = document.getElementById('hero');
    if (hero) {
      const obs = new IntersectionObserver(
        ([entry]) => {
          if (!entry.isIntersecting) {
            nav.style.opacity = '1';
            nav.style.pointerEvents = 'auto';
          } else {
            nav.style.opacity = '0';
            nav.style.pointerEvents = 'none';
          }
        },
        { threshold: 0.1 }
      );
      obs.observe(hero);
    } else {
      nav.style.opacity = '1';
      nav.style.pointerEvents = 'auto';
    }

    // Click → scroll to chapter
    dots.forEach((dot) => {
      dot.addEventListener('click', (e) => {
        e.preventDefault();
        const target = document.querySelector(dot.getAttribute('href'));
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });

      // Hover styles
      dot.addEventListener('mouseenter', () => {
        dot.style.borderColor = '#c9a84c';
        dot.style.background = 'rgba(201,168,76,0.2)';
        dot.style.transform = 'scale(1.2)';
        dot.style.color = '#c9a84c';
      });
      dot.addEventListener('mouseleave', () => {
        if (!dot.classList.contains('active')) {
          dot.style.borderColor = 'rgba(139,115,85,0.5)';
          dot.style.background = 'rgba(10,10,10,0.8)';
          dot.style.transform = 'scale(1)';
          dot.style.color = '#b8b0a0';
        }
      });
    });

    // Active dot tracking on scroll
    const chapters = document.querySelectorAll('[data-chapter]');
    const updateActive = () => {
      const mid = window.scrollY + window.innerHeight / 2;
      let activeNum = null;
      chapters.forEach((ch) => {
        if (mid >= ch.offsetTop && mid < ch.offsetTop + ch.offsetHeight) {
          activeNum = ch.dataset.chapter;
        }
      });
      dots.forEach((dot) => {
        const isActive = dot.dataset.chapterNav === activeNum;
        dot.classList.toggle('active', isActive);
        if (isActive) {
          dot.style.background = '#c9a84c';
          dot.style.borderColor = '#c9a84c';
          dot.style.color = '#0a0a0a';
          dot.style.fontWeight = '700';
          dot.style.transform = 'scale(1.1)';
        } else {
          dot.style.background = 'rgba(10,10,10,0.8)';
          dot.style.borderColor = 'rgba(139,115,85,0.5)';
          dot.style.color = '#b8b0a0';
          dot.style.fontWeight = '400';
          dot.style.transform = 'scale(1)';
        }
      });
    };
    window.addEventListener('scroll', updateActive, { passive: true });
    updateActive();
  });
</script>
