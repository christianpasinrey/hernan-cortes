---
interface Props {
  topSrc: string;
  bottomSrc: string;
  topAlt: string;
  bottomAlt: string;
}
const { topSrc, bottomSrc, topAlt, bottomAlt } = Astro.props;
---

<div class="image-reveal" data-image-reveal>
  <div class="image-reveal__bottom">
    <img src={bottomSrc} alt={bottomAlt} loading="lazy" decoding="async" />
  </div>
  <div class="image-reveal__top" data-reveal-top>
    <img src={topSrc} alt={topAlt} loading="lazy" decoding="async" />
  </div>
  <div class="image-reveal__hint">Mueve el cursor para revelar</div>
</div>

<style>
  .image-reveal {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    overflow: hidden;
    border-radius: 4px;
    cursor: none;
    margin: 3rem 0;
  }

  .image-reveal__bottom,
  .image-reveal__top {
    position: absolute;
    inset: 0;
  }

  .image-reveal__bottom img,
  .image-reveal__top img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .image-reveal__top {
    clip-path: circle(0px at 50% 50%);
  }

  .image-reveal__hint {
    position: absolute;
    bottom: 1.5rem;
    left: 50%;
    transform: translateX(-50%);
    font-size: 0.8rem;
    color: var(--text-secondary);
    font-family: var(--font-quote);
    font-style: italic;
    letter-spacing: 0.1em;
    z-index: 2;
    pointer-events: none;
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .image-reveal__hint { display: none; }
    .image-reveal__top { clip-path: inset(0 50% 0 0); }
  }
</style>
