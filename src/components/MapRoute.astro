---
interface Props {
  mapId: 'atlantic' | 'mexico';
}

const { mapId } = Astro.props;
---

<div class="map-route" data-map-route-container={mapId}>
  {mapId === 'atlantic' ? (
    <svg class="map-route__svg" viewBox="0 0 800 400" xmlns="http://www.w3.org/2000/svg">
      <!-- Simplified Atlantic map -->
      <!-- Spain landmass (right side) -->
      <path d="M620,80 L680,70 L720,90 L740,130 L730,180 L700,200 L660,190 L630,160 L610,120 Z" fill="var(--bg-warm)" stroke="var(--accent-stone)" stroke-width="1" opacity="0.4" />
      <text x="670" y="140" fill="var(--text-secondary)" font-size="11" text-anchor="middle" font-family="var(--font-heading)">ESPAÑA</text>

      <!-- Caribbean islands (left side) -->
      <path d="M100,200 L140,190 L160,200 L150,220 L110,220 Z" fill="var(--bg-warm)" stroke="var(--accent-stone)" stroke-width="1" opacity="0.4" />
      <path d="M170,180 L210,170 L230,185 L220,200 L175,195 Z" fill="var(--bg-warm)" stroke="var(--accent-stone)" stroke-width="1" opacity="0.4" />
      <text x="160" y="250" fill="var(--text-secondary)" font-size="11" text-anchor="middle" font-family="var(--font-heading)">CARIBE</text>

      <!-- Ocean label -->
      <text x="400" y="350" fill="var(--accent-stone)" font-size="10" text-anchor="middle" font-family="var(--font-quote)" font-style="italic" opacity="0.5">Océano Atlántico</text>

      <!-- Route path -->
      <path
        d="M660,170 C550,200 350,280 200,200"
        fill="none"
        stroke="var(--accent-gold)"
        stroke-width="2"
        stroke-dasharray="1000"
        stroke-dashoffset="1000"
        data-map-route
      />

      <!-- Stop: Medellín -->
      <circle cx="660" cy="170" r="6" fill="var(--accent-gold)" opacity="0" data-map-stop="0" />
      <g class="map-route__tooltip" data-map-tooltip="0">
        <rect x="615" y="145" width="90" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="660" y="160" fill="var(--text-primary)" font-size="10" text-anchor="middle" font-family="var(--font-body)">Medellín, 1485</text>
      </g>

      <!-- Stop: La Española -->
      <circle cx="200" cy="200" r="6" fill="var(--accent-gold)" opacity="0" data-map-stop="1" />
      <g class="map-route__tooltip" data-map-tooltip="1">
        <rect x="145" y="170" width="110" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="200" y="185" fill="var(--text-primary)" font-size="10" text-anchor="middle" font-family="var(--font-body)">La Española, 1504</text>
      </g>
    </svg>
  ) : (
    <svg class="map-route__svg" viewBox="0 0 800 500" xmlns="http://www.w3.org/2000/svg">
      <!-- Simplified Mexico map: coast to interior -->
      <!-- Coastline (left) -->
      <path d="M50,100 L80,150 L60,250 L80,350 L100,400 L50,450" fill="none" stroke="var(--accent-stone)" stroke-width="1" opacity="0.3" />

      <!-- Gulf of Mexico -->
      <text x="100" y="80" fill="var(--accent-stone)" font-size="10" font-family="var(--font-quote)" font-style="italic" opacity="0.4">Golfo de México</text>

      <!-- Mountains suggestion -->
      <path d="M400,200 L430,140 L460,200 L490,130 L520,200" fill="none" stroke="var(--accent-stone)" stroke-width="1" opacity="0.2" />

      <!-- Lake Texcoco (right) -->
      <ellipse cx="680" cy="250" rx="60" ry="40" fill="var(--accent-turquoise)" opacity="0.15" stroke="var(--accent-turquoise)" stroke-width="1" />
      <text x="680" y="310" fill="var(--accent-turquoise)" font-size="10" text-anchor="middle" font-family="var(--font-quote)" font-style="italic" opacity="0.6">Lago de Texcoco</text>

      <!-- Route path -->
      <path
        d="M100,300 C150,290 200,280 280,270 C350,260 400,240 450,230 C500,220 550,210 600,230 C650,240 670,250 680,250"
        fill="none"
        stroke="var(--accent-gold)"
        stroke-width="2"
        stroke-dasharray="1000"
        stroke-dashoffset="1000"
        data-map-route
      />

      <!-- Stop: Veracruz -->
      <circle cx="100" cy="300" r="6" fill="var(--accent-gold)" opacity="0" data-map-stop="0" />
      <g class="map-route__tooltip" data-map-tooltip="0">
        <rect x="50" y="270" width="100" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="100" y="285" fill="var(--text-primary)" font-size="10" text-anchor="middle">Veracruz, 1519</text>
      </g>

      <!-- Stop: Cempoala -->
      <circle cx="200" cy="280" r="5" fill="var(--accent-gold)" opacity="0" data-map-stop="1" />
      <g class="map-route__tooltip" data-map-tooltip="1">
        <rect x="155" y="255" width="90" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="200" y="270" fill="var(--text-primary)" font-size="10" text-anchor="middle">Cempoala</text>
      </g>

      <!-- Stop: Tlaxcala -->
      <circle cx="450" cy="230" r="5" fill="var(--accent-gold)" opacity="0" data-map-stop="2" />
      <g class="map-route__tooltip" data-map-tooltip="2">
        <rect x="410" y="205" width="80" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="450" y="220" fill="var(--text-primary)" font-size="10" text-anchor="middle">Tlaxcala</text>
      </g>

      <!-- Stop: Cholula -->
      <circle cx="550" cy="215" r="5" fill="var(--accent-gold)" opacity="0" data-map-stop="3" />
      <g class="map-route__tooltip" data-map-tooltip="3">
        <rect x="510" y="190" width="80" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="550" y="205" fill="var(--text-primary)" font-size="10" text-anchor="middle">Cholula</text>
      </g>

      <!-- Stop: Tenochtitlán -->
      <circle cx="680" cy="250" r="7" fill="var(--accent-turquoise)" opacity="0" data-map-stop="4" />
      <g class="map-route__tooltip" data-map-tooltip="4">
        <rect x="620" y="220" width="120" height="22" rx="3" fill="rgba(10,10,10,0.9)" />
        <text x="680" y="235" fill="var(--text-primary)" font-size="10" text-anchor="middle">Tenochtitlán</text>
      </g>
    </svg>
  )}
</div>

<style>
  .map-route {
    margin: 3rem 0;
    padding: 2rem;
    border: 1px solid rgba(139, 115, 85, 0.2);
    border-radius: 4px;
    background: rgba(26, 21, 16, 0.3);
  }

  .map-route__svg {
    width: 100%;
    height: auto;
  }

  .map-route__tooltip {
    opacity: 0;
    transition: opacity 0.2s;
    pointer-events: none;
  }

  @media (prefers-reduced-motion: reduce) {
    [data-map-route] {
      stroke-dashoffset: 0 !important;
      stroke-dasharray: none !important;
    }
    [data-map-stop] { opacity: 1 !important; }
    .map-route__tooltip { opacity: 1 !important; }
  }
</style>
